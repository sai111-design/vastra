# LLM providers — Groq is the primary, Gemini the fallback.
GROQ_API_KEY=gsk_your_key_here
GOOGLE_API_KEY=AIza_your_key_here

# Storefront MCP host — required, no default.
SHOPIFY_STORE_DOMAIN=your-dev-store.myshopify.com

# Database — defaults to sqlite (zero deps, works on HF Spaces out of the box).
# For local Postgres development, uncomment the two postgres lines below.
DB_BACKEND=sqlite
# SQLITE_PATH defaults to the platform's temp dir (/tmp on Linux/macOS,
# %TEMP%\vastra.db on Windows). Override only if you want persistence:
#   SQLITE_PATH=/data/vastra.db          # HF Space with Persistent Storage
#   SQLITE_PATH=./vastra.db              # next to the source for local dev
# SQLITE_PATH=

# --- Local Postgres (docker compose) — comment the sqlite block above ---
# DB_BACKEND=postgres
# DATABASE_URL=postgresql://vastra:vastra@localhost:55432/vastra

# Agent runtime knobs.
MAX_TOOL_CALLS_PER_TURN=4
CONTEXT_TOKEN_BUDGET=6000

# Observability (LangSmith free tier).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=

# App.
APP_ENV=dev
CORS_ORIGIN=http://localhost:5173
